{
  "statusLine": {
    "type": "command",
    "command": "bash \"$(git rev-parse --show-toplevel)/.claude/statusline-command.sh\""
  },
  "effortLevel": "low",
  "outputStyle": "concise",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.claude/hooks/enforce-tools.py\""
          }
        ]
      }
    ]
  }
}
